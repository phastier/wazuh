<!--
  UniFi UDM Pro Max Rules for Wazuh
  Astier Consulting - Feb/Mar 2026
  Rule IDs: 100300-100399
-->
<group name="unifi,">

  <!-- FIREWALL -->
  <rule id="100300" level="3">
    <decoded_as>unifi-udm-pro-se</decoded_as>
    <description>UniFi: Firewall event</description>
    <group>unifi,firewall,</group>
  </rule>

  <rule id="100301" level="6">
    <if_sid>100300</if_sid>
    <match>Drop|Reject|Block</match>
    <description>UniFi: Firewall DROP/REJECT</description>
    <group>unifi,firewall,drop,</group>
  </rule>

  <rule id="100302" level="0">
    <if_sid>100300</if_sid>
    <match>Allow All Traffic</match>
    <description>UniFi: Firewall Allow All (suppressed)</description>
    <group>unifi,firewall,allow,</group>
  </rule>

  <!-- PROTECT: catch-all (parent for all Protect events) -->
  <rule id="100312" level="4">
    <decoded_as>ubiquiti</decoded_as>
    <description>UniFi Protect: Event - $(data.action)</description>
    <group>unifi,protect,</group>
  </rule>

  <!-- Protect: Smart detection -->
  <rule id="100310" level="5">
    <if_sid>100312</if_sid>
    <match>smartDetectZone|smartDetectLoiterZone</match>
    <description>UniFi Protect: Smart detection - $(data.action)</description>
    <group>unifi,protect,smartdetect,</group>
  </rule>

  <!-- Protect: Sensor motion -->
  <rule id="100311" level="3">
    <if_sid>100312</if_sid>
    <match>sensorMotion</match>
    <description>UniFi Protect: Sensor motion detected</description>
    <group>unifi,protect,motion,</group>
  </rule>

  <!-- Protect: Camera motion -->
  <rule id="100313" level="3">
    <if_sid>100312</if_sid>
    <match>recorded motion</match>
    <description>UniFi Protect: Camera motion detected</description>
    <group>unifi,protect,motion,camera,</group>
  </rule>

  <!-- Protect: Admin activity -->
  <rule id="100316" level="5">
    <if_sid>100312</if_sid>
    <match>adminActivity</match>
    <description>UniFi Protect: Admin activity</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>unifi,protect,admin,audit,</group>
  </rule>

  <!-- Protect: Multiple smart detections correlation -->
  <rule id="100315" level="8" frequency="10" timeframe="60">
    <if_matched_sid>100310</if_matched_sid>
    <description>UniFi Protect: Multiple smart detections - possible intrusion</description>
    <group>unifi,protect,smartdetect,alert,</group>
  </rule>

  <!-- DHCP -->
  <rule id="100320" level="3">
    <decoded_as>unifi-udm-pro-dhcp</decoded_as>
    <description>UniFi: DHCP event</description>
    <group>unifi,dhcp,</group>
  </rule>

  <rule id="100321" level="6">
    <if_sid>100320</if_sid>
    <match>no address range available</match>
    <description>UniFi: DHCP pool exhaustion</description>
    <group>unifi,dhcp,exhaustion,</group>
  </rule>

  <!-- Suppress noise -->
  <rule id="100330" level="0">
    <decoded_as>unifi-udm-pro-services</decoded_as>
    <description>UniFi: System service (suppressed)</description>
    <group>unifi,system,</group>
  </rule>

  <rule id="100331" level="0">
    <decoded_as>unifi-udm-pro-dpi</decoded_as>
    <description>UniFi: DPI stats (suppressed)</description>
    <group>unifi,dpi,</group>
  </rule>

  <!-- WiFi Connected (enriched) -->
  <rule id="100340" level="3">
    <decoded_as>unifi-wifi-connected-parent</decoded_as>
    <description>UniFi: WiFi connected - $(dstuser) on $(system_name) via $(extra_data) [$(srcip)]</description>
    <group>unifi,wifi,connection,</group>
  </rule>

  <!-- WiFi Disconnected (enriched) -->
  <rule id="100341" level="3">
    <decoded_as>unifi-wifi-disconnected-parent</decoded_as>
    <description>UniFi: WiFi disconnected - $(dstuser) from $(system_name) via $(extra_data) [duration=$(data)]</description>
    <group>unifi,wifi,disconnection,</group>
  </rule>

  <!-- WiFi Roamed (enriched) -->
  <rule id="100342" level="3">
    <decoded_as>unifi-wifi-roamed-parent</decoded_as>
    <description>UniFi: WiFi roamed - $(dstuser) from $(url) to $(extra_data) on $(system_name) [$(srcip)]</description>
    <group>unifi,wifi,roaming,</group>
  </rule>

  <!-- Admin Accessed (via dedicated decoder) -->
  <rule id="100343" level="5">
    <decoded_as>unifi-admin-accessed-parent</decoded_as>
    <description>UniFi Network: Admin access</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>unifi,admin,access,authentication,</group>
  </rule>

  <!-- Network CEF catch-all (base for children) -->
  <rule id="100344" level="4">
    <decoded_as>unifi-network-cef-parent</decoded_as>
    <description>UniFi Network: CEF event - $(action)</description>
    <group>unifi,network,</group>
  </rule>

  <!-- Wired Client Connected -->
  <rule id="100345" level="3">
    <if_sid>100344</if_sid>
    <match>Wired Client Connected</match>
    <description>UniFi: Wired client connected</description>
    <group>unifi,wired,connection,</group>
  </rule>

  <!-- Wired Client Disconnected -->
  <rule id="100346" level="3">
    <if_sid>100344</if_sid>
    <match>Wired Client Disconnected</match>
    <description>UniFi: Wired client disconnected</description>
    <group>unifi,wired,disconnection,</group>
  </rule>

  <!-- Device Updated (firmware) -->
  <rule id="100347" level="5">
    <if_sid>100344</if_sid>
    <match>Device Updated</match>
    <description>UniFi: Device firmware updated</description>
    <group>unifi,device,update,</group>
  </rule>

  <!-- UPS Battery Power In Use - CRITICAL -->
  <rule id="100348" level="10">
    <decoded_as>unifi-ups-battery-parent</decoded_as>
    <description>UniFi: UPS on battery power ($(data)) - $(extra_data) [$(srcip)]</description>
    <group>unifi,ups,power,alert,</group>
  </rule>

  <!-- UPS AC Power Restored -->
  <rule id="100349" level="5">
    <decoded_as>unifi-ups-restored-parent</decoded_as>
    <description>UniFi: UPS AC power restored - $(extra_data) [$(srcip)]</description>
    <group>unifi,ups,power,</group>
  </rule>

  <!-- System (suppress) -->
  <rule id="100350" level="0">
    <decoded_as>unifi-system-parent</decoded_as>
    <description>UniFi: System event (suppressed)</description>
    <group>unifi,system,</group>
  </rule>

  <!-- Network Accessed (audit, via catch-all) -->
  <rule id="100351" level="3">
    <if_sid>100344</if_sid>
    <match>Network Accessed</match>
    <description>UniFi Network: Console accessed</description>
    <group>unifi,admin,access,audit,</group>
  </rule>

  <!-- Config Created (audit) -->
  <rule id="100352" level="5">
    <if_sid>100344</if_sid>
    <match>Config Created</match>
    <description>UniFi Network: Configuration created - $(action)</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <group>unifi,config,audit,</group>
  </rule>

  <!-- Config Removed (audit) -->
  <rule id="100353" level="6">
    <if_sid>100344</if_sid>
    <match>Config Removed</match>
    <description>UniFi Network: Configuration removed - $(action)</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <group>unifi,config,audit,</group>
  </rule>

  <!-- Network/Software Updated -->
  <rule id="100354" level="5">
    <if_sid>100344</if_sid>
    <match>Network Updated</match>
    <description>UniFi Network: Software updated - $(action)</description>
    <group>unifi,software,update,</group>
  </rule>

  <!-- Poor AP Link Speed (infra alert) -->
  <rule id="100355" level="6">
    <if_sid>100344</if_sid>
    <match>Poor AP Link Speed</match>
    <description>UniFi Network: Poor AP link speed detected</description>
    <group>unifi,network,infrastructure,alert,</group>
  </rule>

  <!-- ================================ -->
  <!-- UNIFI OS EVENTS                  -->
  <!-- ================================ -->

  <!-- UniFi OS catch-all (parent) -->
  <rule id="100360" level="4">
    <decoded_as>unifi-os-cef-parent</decoded_as>
    <description>UniFi OS: CEF event - $(action)</description>
    <group>unifi,os,</group>
  </rule>

  <!-- UniFi OS: Admin accessed -->
  <rule id="100361" level="5">
    <if_sid>100360</if_sid>
    <match>Admin Accessed</match>
    <description>UniFi OS: Admin accessed console</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>unifi,os,admin,audit,</group>
  </rule>

  <!-- UniFi OS: Application update available -->
  <rule id="100362" level="3">
    <if_sid>100360</if_sid>
    <match>Application Update Available</match>
    <description>UniFi OS: Application update available - $(action)</description>
    <group>unifi,os,update,</group>
  </rule>

  <!-- UniFi OS: Application updated -->
  <rule id="100363" level="5">
    <if_sid>100360</if_sid>
    <match>Application Updated</match>
    <description>UniFi OS: Application updated - $(action)</description>
    <group>unifi,os,update,audit,</group>
  </rule>

</group>
